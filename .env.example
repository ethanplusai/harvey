# Instantly API
INSTANTLY_API_KEY=your_instantly_api_key_here

# LinkedIn (for browser automation)
LINKEDIN_EMAIL=your_linkedin_email
LINKEDIN_PASSWORD=your_linkedin_password

# Cloudflare Browser Rendering (for deep website crawling during training)
# $5/mo paid plan = ~12,000 pages/month. Free plan available with limits.
# Get credentials at: https://dash.cloudflare.com → Workers & Pages → Browser Rendering
CLOUDFLARE_ACCOUNT_ID=your_account_id_here
CLOUDFLARE_API_TOKEN=your_api_token_here

# Hunter.io (optional, free tier = 50 lookups/mo)
HUNTER_API_KEY=your_hunter_api_key_here

# Serper.dev (optional, $5/mo for 2,500 Google searches)
# Most reliable search backend for prospect discovery
# Sign up at: https://serper.dev
SERPER_API_KEY=your_serper_api_key_here

# Calendar (later)
# CALENDLY_API_KEY=your_calendly_api_key_here
